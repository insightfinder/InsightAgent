BAICELLS_URL=https://cloudcore.baicells.com:7085
BAICELLS_USERNAME=
BAICELLS_PASSWORD=

# Device Inventory API Configuration
DEVICE_INVENTORY_API_KEY=
DEVICE_INVENTORY_BASE_URL=
DEVICE_INVENTORY_TIMEOUT_SEC=5
DEVICE_INVENTORY_MAX_RETRY=2
DEVICE_INVENTORY_RETRY_DELAY_MS=500
DEVICE_INVENTORY_REFRESH_HOURS=24

# Extra delay (seconds) after each individual device's BaiCells API request,
# on top of the existing per-batch pacing. Leave at 0 for production - only
# set this locally if the BaiCells API starts rate-limiting during testing.
BAICELLS_PER_DEVICE_DELAY_SEC=0

# InsightFinder Configuration
INSIGHTFINDER_BASE_URL="https://app.insightfinder.com"
INSIGHTFINDER_USER_NAME="user"
INSIGHTFINDER_LICENSE_KEY=""
INSIGHTFINDER_PROJECT_NAME="baicells-metrics"
INSIGHTFINDER_SYSTEM_NAME=""
INSIGHTFINDER_SAMPLING_INTERVAL="15"  # in minutes
