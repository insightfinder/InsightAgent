UISP_URL="uisp_url_goes_here"
UISP_API_TOKEN="token_goes_here"
INSIGHTFINDER_BASE_URL="https://stg.insightfinder.com"
INSIGHTFINDER_USER_NAME="username_goes_here"
INSIGHTFINDER_LICENSE_KEY="license_key_goes_here"
INSIGHTFINDER_PROJECT_NAME="project_name_goes_here"
INSIGHTFINDER_SYSTEM_NAME="system_name_goes_here"
INSIGHTFINDER_SAMPLING_INTERVAL="1"  # in minutes

# Concurrency settings for fetching device details from UISP
# Controls how many concurrent requests are made to /devices/{id}/detail
UISP_MAX_WORKERS="10"  # Number of concurrent workers (default: 5)
UISP_TIMEOUT="30"      # Request timeout in seconds (default: 30)
