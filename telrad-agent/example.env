# eNB metrics via REST NBI — disabled by default. Set to "true" to enable, and
# make sure ACCESSPARKS_TELRAD_URL points at the REST NBI port (see API notes in
# README.md), NOT the BreezeVIEW CLI/SSH port below — they are different services.
# ACCESSPARKS_TELRAD_URL/USERNAME/PASSWORD are only required when this is enabled.
ENABLE_ENB_METRICS=false
ACCESSPARKS_TELRAD_URL=http://216.145.121.132:9382
ACCESSPARKS_TELRAD_USERNAME=
ACCESSPARKS_TELRAD_PASSWORD=

ASSET_CACHE_URL=http://172.31.0.190
ASSET_CACHE_API_KEY=

# BreezeVIEW CLI (SSH) — CPE-side KPIs (RSRP/SINR/RSRQ/CINR/rates).
# Requires sshpass on the host. Optional: if left blank, send_metrics.py sends
# eNB metrics only.
BREEZEVIEW_CLI_HOST=216.145.121.132
BREEZEVIEW_CLI_PORT="9383"
BREEZEVIEW_CLI_USER=
BREEZEVIEW_CLI_PASSWORD=
BREEZEVIEW_CLI_SNAPSHOT_TIMEOUT="240"  # seconds to wait for a kpi-snapshot to finish
BREEZEVIEW_CLI_POLL_INTERVAL="10"      # seconds between snapshot status polls

# InsightFinder Configuration
INSIGHTFINDER_BASE_URL=
INSIGHTFINDER_USER_NAME=
INSIGHTFINDER_LICENSE_KEY=
INSIGHTFINDER_PROJECT_NAME=
INSIGHTFINDER_SYSTEM_NAME=
INSIGHTFINDER_SAMPLING_INTERVAL="5"  # in minutes
