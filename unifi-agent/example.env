UNIFI_API_KEY="your-api-key"

# InsightFinder Configuration
INSIGHTFINDER_URL="https://stg.insightfinder.com"
INSIGHTFINDER_USER_NAME="your-username"
INSIGHTFINDER_LICENSE_KEY="your-license-key"
INSIGHTFINDER_PROJECT_NAME="unifi-metrics"
INSIGHTFINDER_SYSTEM_NAME="your-system-name"
INSIGHTFINDER_SAMPLING_INTERVAL="5"  # in minutes

# Minimum number of 5GHz clients required before RSSI/SNR percentage metrics are computed.
# If an AP has fewer connected clients than the threshold, percentage metrics are reported as 0.
# Average RSSI/SNR are always reported when at least one client is present.
MIN_CLIENTS_RSSI_THRESHOLD="10"
MIN_CLIENTS_SNR_THRESHOLD="10"

# AccessParks inventory API
JIRAASSET_BASE="http://your-accessparks-host"
JIRAASSET_API_KEY="your-accessparks-api-key"

# Optional: path to a derived_metrics.py file defining compound/synthetic metrics.
# Leave unset to disable derived metrics.
# DERIVED_METRICS_SCRIPT="/path/to/derived_metrics.py"