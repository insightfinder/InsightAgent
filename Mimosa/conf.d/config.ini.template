[mimosa]
## Mimosa device connection info
mimosa_uri = https://cloud.mimosa.co
username =
password =
verify_certs = False
network_id =
action_names =
## Optional: Limit number of devices for faster processing (0 = no limit)
max_devices = 0
## Optional: Number of devices to query per API call (default: 25)
api_batch_size = 25
## Optional: Number of data points to be streamed (default: 1)
data_points_count = 5

[agent]
## Fallback componentName when a device is not found in the Device Inventory API (default: AP-Mimosa)
default_component_name = AP-Mimosa
## Fallback displayName when a device is not found in the Device Inventory API
## and Mimosa itself reports no device name (default: UNKNOWN)
default_display_name = UNKNOWN
thread_pool = 5
his_time_range =
agent_http_proxy =
agent_https_proxy =
## Device Inventory API (MAC -> serial/venue/component lookup)
device_inventory_api_key =
device_inventory_base_url = http://54.234.90.98
device_inventory_timeout_sec = 5
device_inventory_max_retry = 2
## How often (in minutes) to refresh devicelookup.json from the Device Inventory API (default: 30)
device_lookup_refresh_minutes = 30

[insightfinder]
user_name =
license_key =
token =
project_name =
system_name = 
project_type = metric
containerize = no
dynamic_metric_type =
sampling_interval = 60s
run_interval = 60s
chunk_size_kb = 2048
if_url = https://app.insightfinder.com
if_http_proxy =
if_https_proxy =
