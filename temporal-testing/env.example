# LLM Configuration

# # OpenAI (recommended)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1

# Anthropic (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=1024

# Optional: Temperature for responses (0.0 - 1.0)
OPENAI_TEMPERATURE=0.7

# Tracing Configuration
# OTLP/Traceserver endpoint for sending traces (Jaeger, Tempo, InsightFinder, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Tracing metadata (InsightFinder-style attributes)
TRACE_PROJECT=
TRACE_SYSTEM=
TRACE_ADMIN_USER=
TRACE_ADMIN_USER_LICENSE=
ENVIRONMENT=dev
SERVICE_NAME=
SERVICE_VERSION=1.0.0



# If not set, traces will be exported to console for debugging