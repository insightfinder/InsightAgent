agent:
  # Agent behavior settings
  log_level: INFO
  data_format: JSON
  timezone: UTC
  filters_include: ""
  filters_exclude: ""

positron:
  # Positron Controller Configuration
  controller_host: localhost
  controller_port: 8443
  username: admin
  password: 123@123
  verify_ssl: false
  max_concurrent_requests: 20

# Device Inventory API Configuration
# Used to look up each device (by MAC, then serial number, then own name) in the
# Asset Registry so metrics can be enriched with the inventory's own identifiers,
# component name, zone, and IP. Same API used by the mimosa, netexperience,
# tarana-gnmic, and baicells agents. Leave api_key/base_url blank to disable
# enrichment entirely.
device_inventory:
  api_key: ""
  base_url: "http://{ip address}"
  timeout_sec: 5
  max_retry: 2
  retry_delay_ms: 500
  refresh_hours: 24

insightfinder:
  # InsightFinder Platform Configuration
  server_url: https://stg.insightfinder.com
  username: 
  license_key: 
  
  # Metrics Project Configuration
  metrics_project_name: Positron-Metrics
  metrics_system_name: Positron
  metrics_project_type: Metric

  # Logs Project Configuration
  logs_project_name: Positron-Logs
  logs_system_name: Positron
  logs_project_type: Log
  
  # Common Configuration
  cloud_type: OnPremise
  instance_type: OnPremise
  is_container: false
  sampling_interval: 60
